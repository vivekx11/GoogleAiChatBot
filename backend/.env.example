# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Weather API (openweathermap.org — free tier)
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# News API (newsapi.org — free tier)
NEWS_API_KEY=your_news_api_key
NEWS_BASE_URL=https://newsapi.org/v2

# Database
DB_PATH=./database/jarvis.db

# CORS
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

# NOTE: No OpenAI key needed!
# All AI (LLM, STT, TTS) runs on-device via RunAnywhere SDK.
# The backend only handles auth, chat history, automations,
# weather/news integrations, and intent routing.
